{
  "name": "Debian with PowerShell",
  "image": "mcr.microsoft.com/devcontainers/base:trixie",
  "features": {
    "ghcr.io/devcontainers/features/powershell:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "pwsh"
      },
      "extensions": [
        "ms-vscode.PowerShell"
      ]
    }
  }
}